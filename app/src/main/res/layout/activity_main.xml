<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="match_parent"
        android:layout_height="555dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Milodón Vending Logo"
        android:scaleType="centerInside"
        android:src="@drawable/logo" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="115dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivLoadingStickers"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginRight="12dp"
            android:contentDescription="Cargando productos"
            android:src="@drawable/loading_stickers" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="487dp"
            android:layout_height="49dp"
            android:letterSpacing="0.03"
            android:text="Iniciando sistema..."
            android:textColor="#FFFFFF"
            android:textSize="34sp" />
    </LinearLayout>

    <GridView
        android:id="@+id/gvProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="3"
        android:verticalSpacing="24dp"
        android:horizontalSpacing="24dp"
        android:stretchMode="columnWidth"
        android:gravity="center" />

    <TextView
        android:id="@+id/tvFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Diseñado por mollyinc.cl"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

</LinearLayout>